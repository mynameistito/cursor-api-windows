{
  "name": "cursor-api-cli-windows",
  "version": "0.1.4",
  "private": true,
  "description": "CLI for a local OpenAI-compatible Cursor API on Windows.",
  "keywords": [
    "cli",
    "composer",
    "cursor",
    "openai",
    "windows"
  ],
  "homepage": "https://github.com/mynameistito/cursor-api-cli-windows#readme",
  "bugs": {
    "url": "https://github.com/mynameistito/cursor-api-cli-windows/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mynameistito/cursor-api-cli-windows.git"
  },
  "bin": {
    "cursor-api": "./dist/cursor-api.exe"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "tsgo --noEmit",
    "build": "bun run scripts/build.ts",
    "stage:bridge": "bun run scripts/stage-bridge.ts",
    "test": "vitest run",
    "check": "ultracite check",
    "knip": "knip",
    "fix": "ultracite fix",
    "prepare": "lefthook install",
    "changeset": "changeset",
    "changeset-add": "bun run scripts/changeset-add.ts",
    "version:packages": "changeset version",
    "release:tag": "changeset tag",
    "release": "bun run scripts/release.ts"
  },
  "dependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260626.1",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "knip": "^6.21.0",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=22"
  }
}
