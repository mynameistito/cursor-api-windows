{
  "name": "cursor-api-monorepo",
  "private": true,
  "description": "Monorepo for cursor-api CLI and documentation site.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:cli": "turbo run dev --filter=cursor-api-cli-windows",
    "dev:web": "turbo run dev --filter=@cursor-api/web",
    "build": "turbo run build",
    "build:cli": "turbo run build --filter=cursor-api-cli-windows",
    "build:web": "turbo run build --filter=@cursor-api/web",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "turbo run check",
    "knip": "turbo run knip",
    "fix": "turbo run fix",
    "prepare": "lefthook install",
    "changeset": "changeset",
    "changeset-add": "bun run apps/cli/scripts/changeset-add.ts",
    "version": "changeset version",
    "version:packages": "changeset version",
    "release:tag": "changeset tag",
    "release": "bun run apps/cli/scripts/release.ts",
    "ci:release": "bun run release ci",
    "stage:bridge": "turbo run stage:bridge --filter=cursor-api-cli-windows"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "turbo": "^2.5.4",
    "ultracite": "7.8.3"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.1.3",
    "@rolldown/binding-win32-x64-msvc": "1.1.3",
    "@typescript/native-preview-linux-x64": "7.0.0-dev.20260626.1",
    "@typescript/native-preview-win32-x64": "7.0.0-dev.20260626.1"
  },
  "trustedDependencies": [
    "@rolldown/binding-linux-x64-gnu",
    "@rolldown/binding-win32-x64-msvc",
    "@typescript/native-preview-linux-x64",
    "@typescript/native-preview-win32-x64",
    "esbuild",
    "lefthook",
    "lightningcss"
  ],
  "overrides": {
    "js-yaml": "4.3.0"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14"
}
