{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "generate-routes"],
      "outputs": ["dist/**", ".output/**"]
    },
    "dev": {
      "dependsOn": ["generate-routes"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build", "generate-routes"]
    },
    "typecheck": {
      "dependsOn": ["^build", "generate-routes"]
    },
    "check": {},
    "cf-typegen": {
      "outputs": ["worker-configuration.d.ts"]
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    },
    "knip": {},
    "fix": {
      "cache": false
    },
    "stage:bridge": {
      "outputs": ["bridge/node.exe", "bridge/node_modules/**"]
    },
    "generate-routes": {
      "outputs": ["src/routeTree.gen.ts"]
    }
  }
}
